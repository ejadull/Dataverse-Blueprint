<?xml version="1.0" encoding="utf-8"?>
<package>
  <metadata>
    <id>DataverseBlueprint</id>
    <version>1.0.13</version>
    <title>Dataverse Blueprint</title>
    <authors>ejadull</authors>
    <owners>ejadull</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <license type="expression">MIT</license>
    <projectUrl>https://github.com/ejadull/Dataverse-Blueprint</projectUrl>
    <repository type="git" url="https://github.com/ejadull/Dataverse-Blueprint" />
    <icon>icons/icon-64.png</icon>
    <iconUrl>https://raw.githubusercontent.com/ejadull/Dataverse-Blueprint/main/icons/icon-64.png</iconUrl>
    <readme>README.md</readme>
    <description>Export your Dataverse entity data model to DBML, Mermaid, and PlantUML. Filter by All, Custom Only, or By Solution. Select individual entities and export in one click.</description>
    <summary>Export Dataverse entity model to DBML, Mermaid, and PlantUML diagrams.</summary>
    <tags>XrmToolBox Dataverse PowerPlatform D365 Diagram Export DBML Mermaid PlantUML Blueprint EntityModel</tags>
    <releaseNotes>v1.0.13 — Fix iconUrl for XrmToolBox portal; update descriptions to remove SVG/PNG references.</releaseNotes>
    <copyright>Copyright 2026 ejadull</copyright>
    <dependencies>
      <group targetFramework=".NETFramework4.8">
        <dependency id="XrmToolBox" version="1.2025.10.74" />
      </group>
    </dependencies>
  </metadata>
  <files>
    <!-- Placeholder to suppress NU5128 (no lib assemblies — plugin package, not a library) -->
    <file src="lib\net48\_._" target="lib\net48\" />

    <!-- Package icon (embedded, replaces deprecated iconUrl) -->
    <file src="icons\icon-64.png" target="icons\" />

    <!-- README for NuGet.org package page -->
    <file src="README.md" target="" />

    <!-- Plugin DLL (Svg.NET and its transitive deps merged in via ILMerge at build time) -->
    <file src="DataverseBlueprint\bin\Release\net48\DataverseBlueprint.dll" target="Plugins\" />
  </files>
</package>
